# EcoTwin — Azure AI Foundry secrets (TEMPLATE).
# Copy this file to backend/.env and fill in your values. backend/.env is
# git-ignored, so your key never gets committed. Leave blank to run fully
# offline (deterministic report). Restart the backend after editing.

# Full chat-completions URL from your deployment's "Target URI" in ai.azure.com
# (My assets -> Models + endpoints -> your deployment). Examples:
#   Azure OpenAI:  https://<resource>.openai.azure.com/openai/deployments/gpt-5.4-nano/chat/completions?api-version=2024-08-01-preview
#   Serverless:    https://<resource>.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview
FOUNDRY_ENDPOINT=

# Key 1 (or Key 2) from the same deployment page.
FOUNDRY_API_KEY=

# Deployment name. Optional on the Azure OpenAI URL (already in the path);
# required on the serverless ".services.ai.azure.com/models/..." URL.
FOUNDRY_MODEL=gpt-5.4-nano

# Optional: request timeout in seconds (default 30).
# FOUNDRY_TIMEOUT=30
